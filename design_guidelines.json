  "instructions_to_main_agent": [
    "Install 'lucide-react' for icons.",
    "Install 'recharts' for analytics.",
    "Install 'date-fns' for date formatting.",
    "Use 'sonner' for all toast notifications.",
    "Use 'TanStack Table' (shadcn table) for the Order List - it's critical for performance with 100+ rows.",
    "For the CSV Import, create a dedicated 'Drag & Drop' zone that parses the file immediately using 'papaparse' (add to package.json) and shows a preview table BEFORE upload.",
    "The 'Order Detail' view should use a 'Timeline' component for tracking history (Ordered -> Dispatch -> Delivery -> Return).",
    "Implement a 'Quick Actions' floating bar or command palette (Cmd+K) for power users to search orders or change status quickly.",
    "Strictly follow the color palette. Do NOT use default blue for primary actions. Use the defined Forest Green."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "Avoid generic 'AI slop' aesthetics. Use defined 'Industrial Zen' identity.",
    "Dark colors look good when used independently without gradients.",
    "Don't make generic centered layouts. Use grids and asymmetry.",
    "Create depth through layered design elements with z-index hierarchy.",
    "Use glass-morphism effects with backdrop filters (12-24px blur) for sticky headers only.",
    "MUST NOT apply universal transition 'transition: all'.",
    "MUST NOT center align the app container.",
    "Always use modern button styles (pill or sharp) relevant to app style.",
    "NEVER use AI assistant Emoji characters for icons.",
    "Every interaction needs micro-animations.",
    "Use 2-3x more spacing than feels comfortable.",
    "Subtle grain textures/noise overlays separate good from extraordinary.",
    "Main agent relies on provided image URLs. Missing categories = placeholder text is FORBIDDEN.",
    "Prioritize using pre-existing components from src/components/ui.",
    "Components MUST use named exports.",
    "Use 'sonner' for toasts."
  ]
}