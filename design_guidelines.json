{
  "design_identity": {
    "name": "Industrial Zen",
    "core_philosophy": "Precision meets Craft. A dashboard that feels like a well-organized digital workshop.",
    "emotional_tone": ["Efficient", "Trustworthy", "Calm", "Tactile"],
    "archetype": "Swiss High-Contrast (Structure) + Organic Earthy (Soul)"
  },
  "typography": {
    "headings": {
      "family": "Manrope",
      "weights": ["400", "600", "800"],
      "usage": "Page titles, Section headers, Modal titles",
      "letter_spacing": "-0.02em"
    },
    "body": {
      "family": "Public Sans",
      "weights": ["400", "500"],
      "usage": "General text, Form labels, Table content"
    },
    "data": {
      "family": "JetBrains Mono",
      "weights": ["400"],
      "usage": "SKUs, Order IDs, Tracking Numbers, JSON snippets"
    }
  },
  "colors": {
    "light": {
      "background": "#F5F5F0",
      "surface": "#FFFFFF",
      "primary": "#1A4D2E",
      "primary_foreground": "#FFFFFF",
      "secondary": "#E8E8E3",
      "secondary_foreground": "#2D3436",
      "accent": "#E07A5F",
      "accent_foreground": "#FFFFFF",
      "border": "#E2E2E2",
      "muted": "#F0F0F0",
      "muted_foreground": "#64748B",
      "destructive": "#EF4444"
    },
    "dark": {
      "background": "#0D1210",
      "surface": "#161C19",
      "primary": "#4ADE80",
      "primary_foreground": "#000000",
      "secondary": "#2A332E",
      "secondary_foreground": "#FFFFFF",
      "accent": "#F97316",
      "accent_foreground": "#FFFFFF",
      "border": "#2A332E",
      "muted": "#2A332E",
      "muted_foreground": "#94A3B8",
      "destructive": "#F87171"
    }
  },
  "layout_strategies": {
    "dashboard": {
      "type": "Bento Grid Mode B (High Density)",
      "grid_cols": "grid-cols-1 md:grid-cols-4 lg:grid-cols-12",
      "gap": "gap-4",
      "widgets": {
        "kpi_summary": "col-span-1 md:col-span-2 lg:col-span-3",
        "main_chart": "col-span-full lg:col-span-8 row-span-2",
        "recent_activity": "col-span-full lg:col-span-4 row-span-2",
        "pending_tasks": "col-span-full lg:col-span-6"
      }
    },
    "tables": {
      "style": "Clean, flat, high-density",
      "row_height": "h-12",
      "header_style": "uppercase text-xs font-bold text-muted-foreground tracking-wider bg-secondary/30"
    },
    "detail_view": {
      "structure": "Split View",
      "left_panel": "w-2/3 (Timeline, Order Details, Customer Info)",
      "right_panel": "w-1/3 (Actions, Quick Tasks, Internal Notes)"
    }
  },
  "components": {
    "buttons": {
      "radius": "rounded-lg",
      "variants": {
        "default": "bg-primary text-primary-foreground hover:bg-primary/90 shadow-sm",
        "outline": "border-2 border-primary/20 hover:bg-primary/5 text-primary",
        "ghost": "hover:bg-secondary text-foreground"
      }
    },
    "cards": {
      "radius": "rounded-xl",
      "shadow": "shadow-sm border border-border/60",
      "padding": "p-6"
    },
    "inputs": {
      "radius": "rounded-md",
      "border": "border-input focus:border-primary focus:ring-1 focus:ring-primary",
      "bg": "bg-background/50"
    },
    "status_badges": {
      "shape": "rounded-full",
      "padding": "px-2.5 py-0.5",
      "font": "text-xs font-medium uppercase tracking-wide"
    }
  },
  "visual_enhancers": {
    "textures": {
      "noise": "opacity-5 mix-blend-overlay fixed inset-0 pointer-events-none z-50",
      "gradients": "None. Use solid colors or very subtle mesh gradients for 'Success' states only."
    },
    "motion": {
      "hover": "transition-transform duration-200 ease-out hover:-translate-y-0.5",
      "click": "active:scale-95",
      "page_load": "animate-in fade-in slide-in-from-bottom-4 duration-500"
    }
  },
